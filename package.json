        "optimize-logos": "bun run scripts/optimize-logos.ts",
        "auto-invert": "bun run scripts/auto-invert.ts",
        "lint": "eslint ."
    },
    "devDependencies": {
        "@eslint/compat": "^1.4.1",
        "@eslint/js": "^9.39.4",
