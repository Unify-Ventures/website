        "@tailwindcss/vite": "^4.3.0",
        "bits-ui": "^2.18.1",
        "gsap": "^3.15.0",
        "isomorphic-dompurify": "^2.36.0",
        "lucide-svelte": "^0.555.0",
        "pocketbase": "^0.26.9",
