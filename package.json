        "@sveltejs/kit": "^2.61.1",
        "@sveltejs/vite-plugin-svelte": "^6.2.4",
        "@tailwindcss/typography": "^0.5.19",
        "@types/node": "^24.12.4",
        "eslint": "^9.39.4",
        "eslint-config-prettier": "^10.1.8",
        "eslint-plugin-svelte": "^3.18.0",
        "globals": "^16.5.0",
        "node-fetch": "^3.3.2",
        "pocketbase-typegen": "^1.5.0",
        "prettier": "^3.8.3",
